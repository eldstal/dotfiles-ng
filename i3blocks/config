[power]
command=~/.config/i3blocks/power.sh
markup=pango
interval=10

[wwan]
command=~/.config/i3blocks/netif.sh wwan0 M
markup=pango
interval=10

[ethernet]
command=~/.config/i3blocks/netif.sh eth0 E
markup=pango
interval=10

[wifi]
command=~/.config/i3blocks/netif.sh wlan0 W
markup=pango
interval=10

[day]
command=date "+%A v%W %F"
interval=5

[time]
command=date "+%T"
interval=5
